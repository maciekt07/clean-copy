{
  "name": "clean-copy",
  "version": "1.0.3",
  "description": "Copy text exactly as selected - no extra links, source credits, or promotional text added by the website.",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maciekt07/clean-copy.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/maciekt07/clean-copy/issues"
  },
  "homepage": "https://github.com/maciekt07/clean-copy#readme",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "test": "playwright test",
    "test:typecheck": "tsc --noEmit",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write",
    "postinstall": "wxt prepare",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.1.42",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "sass": "^1.100.0",
    "typescript": "^6.0.3",
    "wxt": "^0.20.26"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": "24.x"
  },
  "lint-staged": {
    "*.{ts,js,json,html,css}": [
      "biome format --write",
      "biome check"
    ]
  }
}
